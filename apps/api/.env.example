# ============================================================
# apps/api/.env  示例
# 真实 .env 不要提交到 Git（已被 .gitignore 忽略）
# 复制本文件为 .env 并填入真实值
# ============================================================

# ---------- AI Provider（DeepSeek，兼容 OpenAI SDK）----------
# 切换 provider 只需改这 3 个变量，业务代码不动：
#   DeepSeek:  AI_BASE_URL=https://api.deepseek.com           AI_MODEL=deepseek-chat
#   通义千问:  AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   AI_MODEL=qwen-plus
#   Kimi:      AI_BASE_URL=https://api.moonshot.cn/v1         AI_MODEL=moonshot-v1-8k
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=填入你的 DeepSeek Key
AI_MODEL=deepseek-chat

# ---------- 数据库 / Storage（D 提供）----------
# DATABASE_URL=
# DIRECT_URL=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ---------- JWT / 邮件（A 提供）----------
# JWT_SECRET=
# RESEND_API_KEY=
