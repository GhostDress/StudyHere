// StudyHere 数据库 schema
// v2.2 起：MVP 8 张表 + v2.2 新增表（Document / Chunk / ChatMessage / RubricScore /
//          KgEntity / KgRelation / FlashcardReview / Note）
// 设计原则：渐进式重构，Vault 主表保留以向后兼容 v0.1 单文件场景

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- 1. 用户 ----------
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vaults         Vault[]
  plans          StudyPlan[]
  answerRecords  AnswerRecord[]
  wrongQuestions WrongQuestion[]

  @@map("users")
}

// ---------- 2. 验证码 ----------
model OTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@map("otps")
}

// ---------- 3. 上传的资料 ----------
enum VaultStatus {
  pending
  processing
  done
  failed
}

model Vault {
  id          String      @id @default(uuid())
  userId      String
  filename    String // 主文件名（v0.1 兼容）
  fileUrl     String // 主文件 URL（v0.1 兼容）
  status      VaultStatus @default(pending)
  textContent String?     @db.Text // 主文件解析文本（v0.1 兼容）
  errorMsg    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // ---- v2.2 新增字段 ----
  name             String? // 宝库名（用户自起，可空，默认用 filename）
  goal             String? // 学习目标
  agentPersonality String  @default("student") // 智能体人格：student / cert / explorer / strict

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plans       StudyPlan[]
  documents   Document[] // v2.2：1:N 附加文件
  kgEntities  KgEntity[] // v2.2 Day 6：知识图谱节点
  kgRelations KgRelation[] // v2.2 Day 6：知识图谱边

  @@index([userId])
  @@map("vaults")
}

// ---------- 3.1 v2.2 新增：附加文档（多资料宝库） ----------
model Document {
  id          String   @id @default(uuid())
  vaultId     String
  filename    String
  fileUrl     String
  textContent String?  @db.Text
  pageCount   Int?
  fileSizeKb  Int?
  createdAt   DateTime @default(now())

  vault Vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId])
  @@map("documents")
}

// ---------- 4. 学习计划 ----------
model StudyPlan {
  id        String   @id @default(uuid())
  userId    String
  vaultId   String
  title     String
  totalDays Int
  planData  Json
  createdAt DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vault      Vault       @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
  questions  Question[]

  @@index([userId])
  @@index([vaultId])
  @@map("study_plans")
}

// ---------- 5. 闪卡 ----------
model Flashcard {
  id       String @id @default(uuid())
  planId   String
  front    String @db.Text
  back     String @db.Text
  mastery  Int    @default(0)
  dayIndex Int    @default(1)

  plan StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("flashcards")
}

// ---------- 6. 题目 ----------
model Question {
  id          String @id @default(uuid())
  planId      String
  content     String @db.Text
  options     Json
  correct     String
  explanation String @db.Text
  dayIndex    Int    @default(1)

  plan           StudyPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  answerRecords  AnswerRecord[]
  wrongQuestions WrongQuestion[]

  @@index([planId])
  @@map("questions")
}

// ---------- 7. 答题记录 ----------
model AnswerRecord {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  userAnswer String
  isCorrect  Boolean
  answeredAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@map("answer_records")
}

// ---------- 8. 错题本 ----------
model WrongQuestion {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  wrongCount  Int      @default(1)
  analysis    Json?
  lastWrongAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("wrong_questions")
}

// ---------- 9. v2.2 Day 6：知识图谱节点 ----------
// 对应 migration: prisma/migrations/v2.2/002_day6_kg_entities_and_relations.sql
model KgEntity {
  id             String    @id @default(uuid())
  vaultId        String
  name           String // 实体名（如 "MVP"）
  type           String    @default("concept") // concept / method / person / tool / theory / other
  description    String?   @db.Text // hover 浮层短解释
  masteryScore   Int       @default(0) @db.SmallInt // 0-100，前端颜色映射
  testCount      Int       @default(0) // 被考次数，可视化节点大小
  sourcePages    Int[]     @default([]) // 出现的原文页码
  sourceChunkIds String[]  @default([]) // 关联 chunks.id（v2.2 RAG 串联，等 chunks 表上线后回填）
  feedbackCount  Int       @default(0) // v2.3 阶段 B：用户报错累计
  lastFeedbackAt DateTime? // v2.3 阶段 B：最后报错时间
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vault         Vault        @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  relationsFrom KgRelation[] @relation("KgRelationSource")
  relationsTo   KgRelation[] @relation("KgRelationTarget")

  @@unique([vaultId, name])
  @@index([vaultId])
  @@index([vaultId, masteryScore])
  @@map("kg_entities")
}

// ---------- 10. v2.2 Day 6：知识图谱边 ----------
model KgRelation {
  id          String   @id @default(uuid())
  vaultId     String // 冗余存，便于跨表查询不 join
  sourceId    String
  targetId    String
  type        String   @default("related_to") // prerequisite / contains / applies_to / similar_to / related_to
  weight      Float    @default(1.0) // 0.0-1.0 置信度
  description String?
  createdAt   DateTime @default(now())

  vault  Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  source KgEntity @relation("KgRelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target KgEntity @relation("KgRelationTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@index([vaultId])
  @@map("kg_relations")
}
